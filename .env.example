APP_NAME=CoachOS AI Review Service
DATABASE_URL=postgresql+psycopg://postgres:postgres@ai-review-postgres:5432/coachos_ai_review
ATHLETE_SERVICE_INTERNAL_URL=http://host.docker.internal:8002
INTERNAL_SERVICE_NAME=ai-review-service
INTERNAL_SERVICE_TOKEN=replace-ai-token
OUTBOX_BATCH_SIZE=20
OUTBOX_POLL_INTERVAL_SECONDS=2
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_BASE_RETRY_SECONDS=5
