APP_NAME=CoachOS AI Review Service
APP_ENV=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
METRICS_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID
RUN_MIGRATIONS=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@ai-review-postgres:5432/coachos_ai_review
JWT_SECRET_KEY=replace-shared-secret
JWT_ALGORITHM=HS256
ATHLETE_SERVICE_URL=http://host.docker.internal:8002
MEDIA_SERVICE_URL=http://host.docker.internal:8003
ATHLETE_SERVICE_INTERNAL_URL=http://host.docker.internal:8002
INTERNAL_SERVICE_NAME=ai-review-service
INTERNAL_SERVICE_TOKEN=replace-ai-token
OUTBOX_BATCH_SIZE=20
OUTBOX_POLL_INTERVAL_SECONDS=2
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_BASE_RETRY_SECONDS=5
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_REQUEST_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=3
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=3000
PROMPT_VERSION=coachos-review-v1
REVIEW_SCHEMA_VERSION=1
REVIEW_JOB_BATCH_SIZE=5
REVIEW_JOB_POLL_INTERVAL_SECONDS=5
REVIEW_JOB_MAX_ATTEMPTS=3
REVIEW_JOB_BASE_RETRY_SECONDS=10
MAX_COACH_CONTEXT_CHARACTERS=10000
MAX_TRANSCRIPT_CHARACTERS=50000
MAX_MANUAL_OBSERVATIONS=50
MAX_FRAME_OBSERVATIONS=100
MAX_REVIEW_SUMMARY_CHARACTERS=5000
MAX_COACH_NOTES_CHARACTERS=10000
MAX_ATHLETE_MESSAGE_CHARACTERS=3000
MAX_OBSERVATIONS_PER_REVIEW=50
MAX_STRENGTHS_PER_REVIEW=30
MAX_IMPROVEMENT_AREAS_PER_REVIEW=30
MAX_RECOMMENDED_DRILLS_PER_REVIEW=30
MAX_CHANGE_SUMMARY_CHARACTERS=500
INSIGHT_MAX_BATCH_ATHLETES=100
INSIGHT_INTERNAL_SERVICE_TOKEN=replace-with-athlete-service-token
